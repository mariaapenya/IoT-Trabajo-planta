{
  "title": "Monitor de Plantas IoT",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Humedad del suelo - última hora",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 9 },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "targets": [
        {
          "query": "from(bucket: \"plantas\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"sensores_planta\")\n  |> filter(fn: (r) => r._field == \"humedad\")\n  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "Humedad actual",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 9 },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "targets": [
        {
          "query": "from(bucket: \"plantas\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"sensores_planta\")\n  |> filter(fn: (r) => r._field == \"humedad\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Estado de la planta",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 5 },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "targets": [
        {
          "query": "from(bucket: \"plantas\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"sensores_planta\")\n  |> filter(fn: (r) => r._field == \"humedad\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 29.99,
                "result": {
                  "text": "Triste - necesita agua",
                  "color": "red"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 30,
                "to": 59.99,
                "result": {
                  "text": "Normal",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 60,
                "to": 100,
                "result": {
                  "text": "Feliz",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    }
  ]
}
